{
  "openapi": "3.0.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "AppController_getInfo",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppInfoModel"
                }
              }
            }
          }
        },
        "tags": [
          "app"
        ]
      }
    },
    "/children": {
      "get": {
        "operationId": "ChildrenController_findAll",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ChildModel"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "children"
        ]
      }
    },
    "/health": {
      "get": {
        "operationId": "HealthController_getHealth",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponseDto"
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    },
    "/timestamps": {
      "post": {
        "operationId": "TimestampsController_create",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTimestampModel"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimestampModel"
                }
              }
            }
          },
          "400": {
            "description": "Invalid timestamp payload."
          }
        },
        "tags": [
          "timestamps"
        ]
      },
      "get": {
        "operationId": "TimestampsController_findAll",
        "parameters": [
          {
            "name": "updatedAfter",
            "required": false,
            "in": "query",
            "description": "Return only records updated after this ISO date-time.",
            "schema": {
              "example": "2026-06-18T10:00:00.000Z",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TimestampModel"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Invalid updatedAfter value."
          }
        },
        "tags": [
          "timestamps"
        ]
      },
      "delete": {
        "operationId": "TimestampsController_removeAll",
        "parameters": [],
        "responses": {
          "204": {
            "description": "All timestamps deleted."
          }
        },
        "tags": [
          "timestamps"
        ]
      }
    },
    "/timestamps/{id}": {
      "get": {
        "operationId": "TimestampsController_findOne",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimestampModel"
                }
              }
            }
          },
          "400": {
            "description": "Invalid timestamp id."
          },
          "404": {
            "description": "Timestamp not found."
          }
        },
        "tags": [
          "timestamps"
        ]
      },
      "patch": {
        "operationId": "TimestampsController_update",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateTimestampModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TimestampModel"
                }
              }
            }
          },
          "400": {
            "description": "Invalid timestamp payload or id."
          },
          "404": {
            "description": "Timestamp not found."
          }
        },
        "tags": [
          "timestamps"
        ]
      },
      "delete": {
        "operationId": "TimestampsController_remove",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Timestamp deleted."
          },
          "400": {
            "description": "Invalid timestamp id."
          },
          "404": {
            "description": "Timestamp not found."
          }
        },
        "tags": [
          "timestamps"
        ]
      }
    }
  },
  "info": {
    "title": "Baby App API",
    "description": "Backend API for the Baby App native mobile clients.",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "AppInfoModel": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "baby_app_backend"
          },
          "version": {
            "type": "string",
            "example": "0.0.1"
          },
          "status": {
            "type": "string",
            "example": "ok"
          },
          "appEnv": {
            "type": "string",
            "example": "local"
          },
          "nodeEnv": {
            "type": "string",
            "example": "development"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "name",
          "version",
          "status",
          "appEnv",
          "nodeEnv",
          "timestamp"
        ]
      },
      "ChildModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "firstName": {
            "type": "string",
            "example": "Mila"
          },
          "middleName": {
            "type": "object",
            "example": "Rose",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "example": "Sikora"
          },
          "gender": {
            "type": "string",
            "enum": [
              "female",
              "male",
              "non_binary",
              "unspecified"
            ],
            "example": "female"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "example": "2025-06-16"
          },
          "avatarUrl": {
            "type": "object",
            "format": "uri",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "id",
          "firstName",
          "middleName",
          "lastName",
          "gender",
          "dateOfBirth",
          "avatarUrl",
          "createdAt",
          "updatedAt"
        ]
      },
      "HealthResponseDto": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "ok"
          },
          "timestamp": {
            "type": "string",
            "example": "2026-06-16T19:30:00.000Z"
          },
          "uptimeSeconds": {
            "type": "number",
            "example": 12.345
          },
          "appEnv": {
            "type": "string",
            "example": "local"
          },
          "nodeEnv": {
            "type": "string",
            "example": "development"
          }
        },
        "required": [
          "status",
          "timestamp",
          "uptimeSeconds",
          "appEnv",
          "nodeEnv"
        ]
      },
      "CreateTimestampModel": {
        "type": "object",
        "properties": {
          "note": {
            "type": "string",
            "example": "First nap started"
          },
          "dateOccurredAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-17T10:30:00.000Z"
          }
        },
        "required": [
          "note",
          "dateOccurredAt"
        ]
      },
      "TimestampModel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "note": {
            "type": "string",
            "example": "First nap started"
          },
          "dateOccurredAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-17T10:30:00.000Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "deletedAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        },
        "required": [
          "id",
          "note",
          "dateOccurredAt",
          "createdAt",
          "updatedAt"
        ]
      },
      "UpdateTimestampModel": {
        "type": "object",
        "properties": {
          "note": {
            "type": "string",
            "example": "First nap ended"
          },
          "dateOccurredAt": {
            "type": "string",
            "format": "date-time",
            "example": "2026-06-17T11:15:00.000Z"
          }
        }
      }
    }
  }
}
